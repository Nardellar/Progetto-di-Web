<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <meta name="description" content="<%= facility.nome %>">
    <meta name="author" content="Simone Nardella">
    <link href='https://fonts.googleapis.com/css?family=Roboto+Slab:300,400,700' rel='stylesheet' type='text/css'>
    <link href='https://fonts.googleapis.com/css?family=Montserrat:400,700' rel='stylesheet' type='text/css'>
    <link href="https://fonts.googleapis.com/css?family=Dosis:300,400,500,600,700,800" rel="stylesheet">
    <link rel='stylesheet' type='text/css' href="/stylesheets/bootstrap.min.css">
    <link rel='stylesheet' type='text/css' href="/stylesheets/font-awesome.min.css">
    <link rel='stylesheet' type='text/css' href="/stylesheets/style.css">
    <link rel='stylesheet' type='text/css' href="/stylesheets/blog-style.css">
    <link rel='stylesheet' type='text/css' href="/stylesheets/singoloHotel.css">
    <link rel='stylesheet' type='text/css' href="/stylesheets/notifications.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>

<body class="single-page shg-modern">

    <section class="header" id="header">
        <%- include('partials/navbar') %>
    </section>

    <section class="blog_wrapper">
        <div class="container">
            <div class="heading-top">
                <h1><%= facility.nome %></h1>
                <% if (facility.nome_cammino) { %>
                <p class="shg-subtitle">Struttura sul percorso <a href="/sentiero/<%= facility.slug_cammino %>"><%= facility.nome_cammino %></a></p>
                <% } %>
            </div>
            <%- include('partials/notifications') %>
            <div class="row">
                <div class="col-md-9 col-sm-8">
                    <% const galleryImages = (facilityImages && facilityImages.length)
                      ? facilityImages.map(function(img) { return img.percorso_immagine; })
                      : (facility.immagine ? [facility.immagine] : []); %>
                    <div class="post_block">
                        <div class="col-md-12">
                            <% if (galleryImages.length > 0) { %>
                            <div id="shgHeroCarousel" class="carousel slide shg-hero-carousel" data-ride="carousel">
                                <div class="carousel-inner" role="listbox">
                                    <% galleryImages.forEach(function(imagePath, index) { %>
                                    <% const imageUrl = imagePath.startsWith('http') ? imagePath : ('/images/' + imagePath); %>
                                    <div class="item <%= index === 0 ? 'active' : '' %>">
                                        <img src="<%= imageUrl %>" alt="<%= facility.nome %> - foto <%= index + 1 %>" class="shg-hero-image">
                                    </div>
                                    <% }); %>
                                </div>
                                <% if (galleryImages.length > 1) { %>
                                <a class="left carousel-control" href="#shgHeroCarousel" role="button" data-slide="prev">
                                    <span class="glyphicon glyphicon-chevron-left" aria-hidden="true"></span>
                                    <span class="sr-only">Precedente</span>
                                </a>
                                <a class="right carousel-control" href="#shgHeroCarousel" role="button" data-slide="next">
                                    <span class="glyphicon glyphicon-chevron-right" aria-hidden="true"></span>
                                    <span class="sr-only">Successiva</span>
                                </a>
                                <% } %>
                            </div>
                            <% } else { %>
                            <div class="facility-hero-placeholder">
                                <i class="fa fa-home fa-5x facility-placeholder-icon"></i>
                            </div>
                            <% } %>
                            <div class="single-blog-content">
                                <h2><%= facility.nome %></h2>
                                <p class="facility-description">
                                    <% if (facility.indirizzo) { %>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10m0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6"/>
                                    </svg>
                                    <%= facility.indirizzo %>, <%= facility.citta %><br>
                                    <% } %>
                                    <%= facility.descrizione %>
                                </p>
                                <% if (facility.capacita) { %>
                                <p><strong>Capacità:</strong> <%= facility.capacita %> ospiti</p>
                                <% } %>
                            </div>
                        </div>
                        <div class="clearfix"></div>
                    </div>

                    <div class="author_block">
                        <h2>Host</h2>
                        <% const hostImg = hostOwner && hostOwner.immagine_profilo
                          ? (hostOwner.immagine_profilo.startsWith('http') ? hostOwner.immagine_profilo : ('/images/' + hostOwner.immagine_profilo))
                          : null; %>
                        <div class="col-md-2 col-sm-2">
                            <% if (hostImg) { %>
                            <img src="<%= hostImg %>" alt="<%= hostOwner ? (hostOwner.nome + ' ' + hostOwner.cognome) : 'Gestore struttura' %>" class="img-responsive shg-host-photo">
                            <% } %>
                        </div>
                        <div class="col-md-10 col-sm-10 no-padding">
                            <% if (hostOwner) { %>
                            <h3><%= hostOwner.nome %> <%= hostOwner.cognome %></h3>
                            <span><%= hostAnniPiattaforma %> <%= hostAnniPiattaforma === 1 ? 'anno' : 'anni' %> sulla piattaforma</span>
                            <p>Ciao, sono <%= hostOwner.nome %> <%= hostOwner.cognome %>, gestore di <strong><%= facility.nome %></strong><% if (facility.citta) { %> a <%= facility.citta %><% } %>. Sono disponibile per rispondere alle domande qui sotto e per aiutarti a organizzare al meglio il tuo soggiorno.</p>
                            <% } else { %>
                            <h3>Gestore della struttura</h3>
                            <span>Host registrato</span>
                            <p>Il gestore di <strong><%= facility.nome %></strong> e raggiungibile tramite le domande e le prenotazioni sul sito.</p>
                            <% } %>
                        </div>
                        <div class="clearfix"></div>
                    </div>

                    <div class="comments" id="qa-section">
                        <h2><%= questions.length %> Domand<%= questions.length === 1 ? 'a' : 'e' %></h2>

                        <% questions.forEach(function(q) { %>
                        <% const qImg = q.immagine_profilo ? (q.immagine_profilo.startsWith('http') ? q.immagine_profilo : ('/images/' + q.immagine_profilo)) : '/images/fotoProfiloAnonima.jpg'; %>
                        <div class="comment_block" id="question-<%= q.id %>">
                            <div class="col-md-10 col-sm-10">
                                <div class="col-md-2 col-sm-2"><img src="<%= qImg %>" class="qa-avatar"></div>
                                <div class="col-md-10 col-sm-10 no-padding">
                                    <h3><%= q.nome_autore %><%= q.email_autore ? '' : ' (Anonimo)' %></h3>
                                    <span><%= new Date(q.creato_il).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' }) %> <%= new Date(q.creato_il).toLocaleTimeString('it-IT', { hour: '2-digit', minute: '2-digit' }) %></span>
                                    <p><%= q.testo %></p>
                                </div>
                            </div>
                            <div class="col-md-2 col-sm-2 question-actions">
                                <% if (canReply) { %>
                                <button type="button" class="readmore js-reply-toggle" data-reply-target="reply-form-<%= q.id %>">Rispondi</button>
                                <% } %>
                                <% if (user && q.email_autore && user.email === q.email_autore) { %>
                                <form action="/domanda/<%= q.id %>/cancella" method="post" class="delete-question-form">
                                    <input type="hidden" name="redirect_to" value="/struttura/<%= facility.id %>">
                                    <button type="submit" class="readmore delete-question-btn" onclick="return confirm('Vuoi davvero cancellare questa domanda?')">Cancella</button>
                                </form>
                                <% } %>
                            </div>
                            <% if (canReply) { %>
                            <div class="col-md-12">
                                <form id="reply-form-<%= q.id %>" class="reply-form-collapsed reply-inline-form" action="/domanda/<%= q.id %>/rispondi" method="post">
                                    <input type="hidden" name="redirect_to" value="/struttura/<%= facility.id %>">
                                    <div class="form-group">
                                        <label for="reply-text-<%= q.id %>" class="sr-only">Scrivi la risposta</label>
                                        <textarea id="reply-text-<%= q.id %>" name="testo" class="form-control" rows="3" placeholder="Scrivi la tua risposta..." required></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-primary btn-sm"><i class="fa fa-reply"></i> Invia risposta</button>
                                </form>
                            </div>
                            <% } %>
                            <div class="clearfix"></div>
                        </div>

                        <% q.answers.forEach(function(a) { %>
                        <% const aImg = a.immagine_risponditore ? (a.immagine_risponditore.startsWith('http') ? a.immagine_risponditore : ('/images/' + a.immagine_risponditore)) : '/images/Host1.jpg'; %>
                        <div class="comment_block col-md-offset-1">
                            <div class="col-md-10 col-sm-10">
                                <div class="col-md-2 col-sm-2"><img src="<%= aImg %>" class="qa-avatar"></div>
                                <div class="col-md-10 col-sm-10 no-padding">
                                    <h3><%= a.nome_risponditore ? (a.nome_risponditore + ' ' + (a.cognome_risponditore || '')) : a.email_risponditore %></h3>
                                    <span><%= new Date(a.creato_il).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' }) %> <%= new Date(a.creato_il).toLocaleTimeString('it-IT', { hour: '2-digit', minute: '2-digit' }) %></span>
                                    <p><%= a.testo %></p>
                                </div>
                            </div>
                            <% if (user && user.role === 'ristoratore' && user.email === a.email_risponditore) { %>
                            <div class="col-md-2 col-sm-2 question-actions">
                                <button type="button" class="readmore js-reply-toggle" data-reply-target="edit-answer-form-<%= a.id %>">Modifica</button>
                                <form action="/risposta/<%= a.id %>/cancella" method="post" class="delete-question-form">
                                    <input type="hidden" name="redirect_to" value="/struttura/<%= facility.id %>">
                                    <button type="submit" class="readmore delete-question-btn" onclick="return confirm('Vuoi davvero cancellare questa risposta?')">Cancella</button>
                                </form>
                            </div>
                            <div class="col-md-12">
                                <form id="edit-answer-form-<%= a.id %>" class="reply-form-collapsed reply-inline-form" action="/risposta/<%= a.id %>/modifica" method="post">
                                    <input type="hidden" name="redirect_to" value="/struttura/<%= facility.id %>">
                                    <div class="form-group">
                                        <label for="edit-answer-text-<%= a.id %>" class="sr-only">Modifica risposta</label>
                                        <textarea id="edit-answer-text-<%= a.id %>" name="testo" class="form-control" rows="3" required><%= a.testo %></textarea>
                                    </div>
                                    <button type="submit" class="btn btn-primary btn-sm"><i class="fa fa-save"></i> Salva modifica</button>
                                </form>
                            </div>
                            <% } %>
                            <div class="clearfix"></div>
                        </div>
                        <% }); %>
                        <% }); %>

                        <% const strutturaProprietario = user && user.role === 'ristoratore' && user.email === facility.email_ristoratore; %>
                        <div class="leave_reply">
                            <h2>Fai una domanda</h2>
                            <% if (strutturaProprietario) { %>
                            <p class="text-muted owner-self-question-note">Come gestore di questa struttura non puoi inviare domande a te stesso. Usa la sezione <a href="/gestione">Gestione strutture</a> per le comunicazioni con gli ospiti.</p>
                            <% } else { %>
                            <form action="/struttura/<%= facility.id %>/domanda" method="post">
                                <% if (!user) { %>
                                <div class="form-group col-md-12 col-sm-12">
                                    <label for="domanda-nome" class="sr-only">Nome</label>
                                    <input id="domanda-nome" class="form-control" placeholder="Nome o nickname*" name="nome_autore" type="text" required>
                                </div>
                                <% } else { %>
                                <p class="help-block">Stai scrivendo come <strong><%= user.nome %> <%= user.cognome %></strong>.</p>
                                <% } %>
                                <div class="form-group col-md-12 col-sm-12">
                                    <label for="domanda-testo" class="sr-only">La tua domanda</label>
                                    <textarea id="domanda-testo" class="form-control" rows="6" placeholder="La tua domanda..." name="testo" required></textarea>
                                </div>
                                <div class="form-group col-md-12 col-sm-12">
                                    <button type="submit" class="btn btn-primary">Invia domanda</button>
                                </div>
                            </form>
                            <% } %>
                        </div>
                        <div class="clearfix"></div>

                        <div class="reviews-block" id="reviews-section">
                            <h2>Recensioni (<%= reviewStats.totale || 0 %>)</h2>
                            <p class="review-summary">
                                <% if (reviewStats.media) { %>
                                Media voti: <strong><%= reviewStats.media %>/5</strong>
                                <% } else { %>
                                Nessuna recensione ancora disponibile.
                                <% } %>
                            </p>

                            <% if (reviews && reviews.length) { %>
                            <% reviews.forEach(function(r) { %>
                            <div class="review-item">
                                <div class="review-item-header">
                                    <strong><%= r.nome %> <%= r.cognome %></strong>
                                    <span class="review-stars"><%= '★'.repeat(r.voto) %><%= '☆'.repeat(5 - r.voto) %></span>
                                </div>
                                <% if (r.testo) { %>
                                <p><%= r.testo %></p>
                                <% } %>
                                <small class="review-stay-date">
                                    Soggiorno dal
                                    <%= new Date(r.soggiorno_da || r.creato_il).toLocaleDateString('it-IT') %>
                                    al
                                    <%= new Date(r.soggiorno_a || r.creato_il).toLocaleDateString('it-IT') %>
                                </small>
                            </div>
                            <% }); %>
                            <% } %>

                            <% if (user && user.role === 'camminatore') { %>
                            <% if (canReview) { %>
                            <form class="review-form" action="/struttura/<%= facility.id %>/recensione" method="post">
                                <h3><%= myReview ? 'Aggiorna la tua recensione' : 'Lascia una recensione' %></h3>
                                <div class="rating-input">
                                    <% [5,4,3,2,1].forEach(function(star) { %>
                                    <input type="radio" id="rating-<%= star %>" name="voto" value="<%= star %>" <%= myReview && myReview.voto === star ? 'checked' : '' %> <%= !myReview && star === 5 ? 'checked' : '' %>>
                                    <label for="rating-<%= star %>" title="<%= star %> stelle">★</label>
                                    <% }); %>
                                </div>
                                <div class="form-group">
                                    <label for="review-text" class="sr-only">Testo recensione</label>
                                    <textarea id="review-text" name="testo" class="form-control" rows="4" placeholder="Racconta la tua esperienza (opzionale)"><%= myReview && myReview.testo ? myReview.testo : '' %></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary">Invia recensione</button>
                            </form>
                            <% } else { %>
                            <p class="text-muted">Puoi lasciare una recensione solo dopo aver completato un soggiorno in questa struttura.</p>
                            <% } %>
                            <% } else if (!user) { %>
                            <p><a href="/registrazione">Accedi</a> come camminatore per lasciare una recensione.</p>
                            <% } %>
                        </div>
                        <div class="clearfix"></div>
                    </div>
                </div>

                <div class="col-md-3 col-sm-4">
                    <div class="sidebar">
                        <div class="widget">
                            <h2 class="heading">Informazioni</h2>
                            <ul>
                                <li><strong>Città:</strong> <%= facility.citta %></li>
                                <% if (facility.indirizzo) { %>
                                <li><strong>Indirizzo:</strong> <%= facility.indirizzo %></li>
                                <% } %>
                                <% if (facility.prezzo_notte) { %>
                                <li><strong>Prezzo/notte:</strong> &euro;<%= facility.prezzo_notte.toFixed(2) %></li>
                                <% } %>
                                <% if (facility.capacita) { %>
                                <li><strong>Capacità:</strong> <%= facility.capacita %> ospiti</li>
                                <% } %>
                            </ul>
                        </div>

                        <div class="widget">
                            <%- include('partials/facility-services') %>
                        </div>

                        <% if (user) { %>
                        <section class="col-md-12 reservation-box" id="booking-section">
                            <div class="reservation-form">
                                <h3>Prenota il tuo soggiorno</h3>
                                <form action="/struttura/<%= facility.id %>/prenota" method="post">
                                    <div class="form-group">
                                        <label for="check_in">Check-in:</label>
                                        <input id="check_in" name="check_in" class="form-control" type="date" min="<%= new Date().toISOString().split('T')[0] %>" required>
                                    </div>
                                    <div class="form-group">
                                        <label for="check_out">Check-out:</label>
                                        <input id="check_out" name="check_out" class="form-control" type="date" min="<%= new Date().toISOString().split('T')[0] %>" required>
                                    </div>
                                    <div class="form-group">
                                        <label for="numero_ospiti">Numero di ospiti:</label>
                                        <input id="numero_ospiti" name="numero_ospiti" class="form-control" type="number" min="1" max="10" value="1" required>
                                    </div>
                                    <button type="submit" class="btn btn-primary">Prenota ora</button>
                                </form>
                            </div>
                        </section>
                        <% } else { %>
                        <div class="widget">
                            <p><a href="/registrazione">Accedi</a> per prenotare questa struttura.</p>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
        <div class="clearfix"></div>
    </section>

    <%- include('partials/footer') %>

    <script src="/javascripts/jquery.min.js"></script>
    <script src="/javascripts/bootstrap.min.js"></script>
    <script src="/javascripts/notifications.js"></script>
    <script src="/javascripts/reply-toggle.js"></script>
    <script src="/javascripts/booking-validation.js"></script>
</body>

</html>
