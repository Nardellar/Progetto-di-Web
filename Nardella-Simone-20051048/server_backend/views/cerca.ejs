<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="author" content="Simone Nardella">
    <title><%= title %></title>
    <link rel="stylesheet" href="/stylesheets/bootstrap.min.css">
    <link href="/stylesheets/style.css" rel="stylesheet">
    <link rel="stylesheet" href="/stylesheets/font-awesome.min.css">
    <link href="https://fonts.googleapis.com/css?family=Dosis:300,400,500,600,700,800" rel="stylesheet">
</head>

<body>
    <section class="header" id="header">
        <%- include('partials/navbar') %>
    </section>

    <section style="padding: 40px 0; min-height: 60vh;">
        <div class="container">
            <h1>Ricerca</h1>

            <form action="/cerca" method="get" class="form-inline" style="margin-bottom: 30px;">
                <div class="form-group" style="width: 70%;">
                    <label for="cerca-q" class="sr-only">Cerca percorsi, strutture, città</label>
                    <input id="cerca-q" type="text" name="q" class="form-control" style="width: 100%;"
                        placeholder="Cerca percorsi, strutture, città..." value="<%= query %>" autofocus>
                </div>
                <button type="submit" class="btn btn-primary"><i class="fa fa-search"></i> Cerca</button>
            </form>

            <% if (query) { %>
            <p class="lead">Risultati per "<strong><%= query %></strong>"</p>

            <% if (trails.length === 0 && facilities.length === 0) { %>
            <div class="alert alert-info">Nessun risultato trovato. Prova con termini diversi.</div>
            <% } %>

            <!-- Percorsi -->
            <% if (trails.length > 0) { %>
            <h3><i class="fa fa-map-signs"></i> Percorsi (<%= trails.length %>)</h3>
            <div class="row">
                <% trails.forEach(function(t) { %>
                <div class="col-md-4" style="margin-bottom: 20px;">
                    <div class="panel panel-default">
                        <% if (t.immagine) { %>
                        <img src="/images/<%= t.immagine %>" alt="<%= t.nome %>" style="width:100%; height:180px; object-fit:cover;">
                        <% } %>
                        <div class="panel-body">
                            <h4><a href="/sentiero/<%= t.slug %>"><%= t.nome %></a></h4>
                            <p><i class="fa fa-map-marker"></i> <%= t.citta_partenza %> &rarr; <%= t.citta_arrivo %></p>
                            <% if (t.regione) { %>
                            <p><small class="text-muted"><%= t.regione %></small></p>
                            <% } %>
                            <a href="/sentiero/<%= t.slug %>" class="btn btn-sm btn-default">Scopri il percorso</a>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
            <% } %>

            <!-- Strutture -->
            <% if (facilities.length > 0) { %>
            <h3><i class="fa fa-building"></i> Strutture (<%= facilities.length %>)</h3>
            <div class="row">
                <% facilities.forEach(function(f) { %>
                <div class="col-md-4" style="margin-bottom: 20px;">
                    <div class="panel panel-default">
                        <% if (f.immagine) { %>
                        <img src="/images/<%= f.immagine %>" alt="<%= f.nome %>" style="width:100%; height:180px; object-fit:cover;">
                        <% } else { %>
                        <div style="height:180px;background:#e9ecef;display:flex;align-items:center;justify-content:center;">
                            <i class="fa fa-home fa-3x" style="color:#aaa;"></i>
                        </div>
                        <% } %>
                        <div class="panel-body">
                            <h4><a href="/struttura/<%= f.id %>"><%= f.nome %></a></h4>
                            <p><i class="fa fa-map-marker"></i> <%= f.citta %></p>
                            <% if (f.prezzo_notte) { %>
                            <p><strong>&euro;<%= f.prezzo_notte.toFixed(2) %></strong> / notte</p>
                            <% } %>
                            <% if (f.nome_cammino) { %>
                            <p><small>Sul percorso: <a href="/sentiero/<%= f.slug_cammino %>"><%= f.nome_cammino %></a></small></p>
                            <% } %>
                            <a href="/struttura/<%= f.id %>" class="btn btn-sm btn-primary">Dettagli</a>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
            <% } %>

            <% } %>
        </div>
    </section>

    <%- include('partials/footer') %>

    <script src="/javascripts/jquery.min.js"></script>
    <script src="/javascripts/bootstrap.min.js"></script>
</body>

</html>
